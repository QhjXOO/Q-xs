---
/**
 * Header.astro — Geek-style fixed navigation
 */
const navItems = [
  { label: 'Dashboard', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'Reports', href: '/reports' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="main-header">
  <div class="header__inner container">
    <a href="/" class="header__logo">
      <span class="header__logo-bracket">[</span>
      <span class="header__logo-text">Q:XS</span>
      <span class="header__logo-bracket">]</span>
    </a>

    <nav class="header__nav" id="main-nav">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['header__nav-link', { 'active': currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
        >
          <span class="nav-indicator">›</span>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="header__status">
      <span class="status-dot"></span>
      <span class="status-text text-mono">ONLINE</span>
    </div>

    <button class="header__mobile-toggle" id="mobile-toggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--header-height);
    background: rgba(10,10,15,0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: var(--border-subtle);
    z-index: 1000;
    transition: all var(--transition-base);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .header__logo {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    display: flex; align-items: center; gap: 2px;
    transition: color var(--transition-fast);
  }
  .header__logo:hover { color: var(--accent-green); }
  .header__logo-bracket { color: var(--accent-green); }
  .header__logo-text { color: var(--text-primary); }

  .header__nav {
    display: flex; gap: var(--space-2);
  }

  .header__nav-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
    text-decoration: none;
    position: relative;
  }
  .header__nav-link .nav-indicator {
    color: var(--accent-green);
    margin-right: 4px;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }
  .header__nav-link:hover,
  .header__nav-link.active {
    color: var(--text-primary);
    background: rgba(255,255,255,0.05);
  }
  .header__nav-link:hover .nav-indicator,
  .header__nav-link.active .nav-indicator {
    opacity: 1;
  }

  .header__status {
    display: flex; align-items: center; gap: var(--space-2);
  }
  .status-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent-green);
    animation: pulse-glow 2s ease-in-out infinite;
  }
  .status-text {
    font-size: var(--text-xs);
    color: var(--accent-green);
    letter-spacing: 0.1em;
  }

  .header__mobile-toggle {
    display: none;
    flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer;
    padding: var(--space-2);
  }
  .header__mobile-toggle span {
    display: block; width: 20px; height: 2px;
    background: var(--text-secondary);
    transition: all var(--transition-fast);
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
      position: absolute;
      top: var(--header-height);
      left: 0; right: 0;
      background: rgba(10,10,15,0.95);
      backdrop-filter: blur(20px);
      flex-direction: column;
      padding: var(--space-4);
      border-bottom: var(--border-subtle);
    }
    .header__nav.open { display: flex; }
    .header__status { display: none; }
    .header__mobile-toggle { display: flex; }
  }
</style>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const nav = document.getElementById('main-nav');
  toggle?.addEventListener('click', () => {
    nav?.classList.toggle('open');
  });
</script>
