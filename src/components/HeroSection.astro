---
/**
 * HeroSection.astro — Animated landing hero with terminal aesthetic
 */
---

<section class="hero" id="hero-section">
  <div class="hero__bg">
    <div class="hero__grid"></div>
    <div class="hero__orb hero__orb--1"></div>
    <div class="hero__orb hero__orb--2"></div>
  </div>

  <div class="hero__content container">
    <div class="hero__terminal animate-in">
      <div class="terminal-bar">
        <span class="terminal-dot terminal-dot--red"></span>
        <span class="terminal-dot terminal-dot--yellow"></span>
        <span class="terminal-dot terminal-dot--green"></span>
        <span class="terminal-title text-mono">system://init</span>
      </div>
      <div class="terminal-body">
        <p class="terminal-line">
          <span class="prompt">$</span>
          <span class="cmd">./launch</span>
          <span class="flag">--mode=geek</span>
          <span class="flag">--theme=dark</span>
        </p>
      </div>
    </div>

    <h1 class="hero__title animate-in">
      <span class="hero__title-line">Decentralized</span>
      <span class="hero__title-line text-gradient">Intelligence Hub</span>
    </h1>

    <p class="hero__subtitle animate-in">
      Real-time crypto analytics, deep research reports, and bleeding-edge Web3 insights — all from the edge.
    </p>

    <div class="hero__actions animate-in">
      <a href="#crypto-dashboard" class="btn btn--primary">
        <span class="btn__icon">◈</span>
        Live Dashboard
      </a>
      <a href="/reports" class="btn btn--ghost">
        <span class="btn__icon">⟫</span>
        Research Portal
      </a>
    </div>

    <div class="hero__stats animate-in">
      <div class="stat">
        <span class="stat__value text-mono">5</span>
        <span class="stat__label">Assets Tracked</span>
      </div>
      <div class="stat">
        <span class="stat__value text-mono">24/7</span>
        <span class="stat__label">Real-time Data</span>
      </div>
      <div class="stat">
        <span class="stat__value text-mono">Edge</span>
        <span class="stat__label">Deployment</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-height);
    overflow: hidden;
  }

  /* Background effects */
  .hero__bg { position: absolute; inset: 0; z-index: 0; }

  .hero__grid {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(circle at 25% 25%, rgba(0,255,136,0.03) 0%, transparent 50%),
      radial-gradient(circle at 75% 75%, rgba(0,212,255,0.03) 0%, transparent 50%);
  }

  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    animation: float 8s ease-in-out infinite;
  }
  .hero__orb--1 {
    width: 400px; height: 400px;
    background: rgba(0,255,136,0.06);
    top: 10%; right: 10%;
  }
  .hero__orb--2 {
    width: 300px; height: 300px;
    background: rgba(0,212,255,0.05);
    bottom: 20%; left: 5%;
    animation-delay: -4s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    33%      { transform: translate(30px, -30px); }
    66%      { transform: translate(-20px, 20px); }
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
  }

  /* Terminal widget */
  .hero__terminal {
    display: inline-block;
    background: var(--bg-secondary);
    border: var(--border-card);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: var(--space-8);
  }
  .terminal-bar {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 12px;
    background: var(--bg-tertiary);
  }
  .terminal-dot { width: 10px; height: 10px; border-radius: 50%; }
  .terminal-dot--red    { background: #ff5f57; }
  .terminal-dot--yellow { background: #ffbd2e; }
  .terminal-dot--green  { background: #28c840; }
  .terminal-title {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    margin-left: 8px;
  }
  .terminal-body { padding: 12px 16px; }
  .terminal-line {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    display: flex; gap: 8px; flex-wrap: wrap;
    margin: 0;
  }
  .prompt { color: var(--accent-green); }
  .cmd    { color: var(--text-primary); }
  .flag   { color: var(--accent-cyan); }

  /* Title */
  .hero__title {
    font-size: clamp(2.5rem, 6vw, var(--text-6xl));
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }
  .hero__title-line { display: block; }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 600px;
    margin-bottom: var(--space-8);
  }

  /* Buttons */
  .hero__actions {
    display: flex; gap: var(--space-4); flex-wrap: wrap;
    margin-bottom: var(--space-12);
  }

  .btn {
    display: inline-flex; align-items: center; gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all var(--transition-base);
    cursor: pointer;
    border: none;
  }
  .btn--primary {
    background: var(--accent-green);
    color: #0a0a0f;
  }
  .btn--primary:hover {
    background: #33ff99;
    box-shadow: 0 0 30px rgba(0,255,136,0.3);
    transform: translateY(-1px);
    color: #0a0a0f;
  }
  .btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    border: var(--border-card);
  }
  .btn--ghost:hover {
    color: var(--text-primary);
    border-color: rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.03);
  }
  .btn__icon { font-size: 1.1em; }

  /* Stats */
  .hero__stats {
    display: flex; gap: var(--space-10);
  }
  .stat { display: flex; flex-direction: column; gap: 2px; }
  .stat__value {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--accent-green);
  }
  .stat__label {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  @media (max-width: 768px) {
    .hero { min-height: auto; padding: calc(var(--header-height) + var(--space-12)) 0 var(--space-12); }
    .hero__stats { gap: var(--space-6); }
  }
</style>
