---
/**
 * ReportCard.astro — Card for research report listing
 */
interface Props {
  title: string;
  slug: string;
  date: Date;
  summary: string;
  category: string;
}

const { title, slug, date, summary, category } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`/reports/${slug}`} class="report-card card">
  <div class="report-card__top">
    <span class="tag tag--purple">{category}</span>
    <span class="report-card__date text-mono">{formattedDate}</span>
  </div>
  <h3 class="report-card__title">{title}</h3>
  <p class="report-card__summary">{summary}</p>
  <span class="report-card__link text-mono">
    <span class="accent">⟫</span> View Report
  </span>
</a>

<style>
  .report-card {
    display: flex; flex-direction: column;
    text-decoration: none;
    gap: var(--space-3);
  }
  .report-card__top {
    display: flex; align-items: center; justify-content: space-between;
  }
  .report-card__date {
    font-size: var(--text-xs);
    color: var(--text-tertiary);
  }
  .report-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    transition: color var(--transition-fast);
  }
  .report-card:hover .report-card__title {
    color: var(--accent-purple);
  }
  .report-card__summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .report-card__link {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-top: auto;
    padding-top: var(--space-3);
    transition: color var(--transition-fast);
  }
  .report-card__link .accent { color: var(--accent-purple); }
  .report-card:hover .report-card__link { color: var(--accent-purple); }
</style>
