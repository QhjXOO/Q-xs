---
/**
 * index.astro — Landing page: Hero + Crypto Dashboard + Latest Content
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CryptoTicker from '../components/CryptoTicker.astro';
import BlogCard from '../components/BlogCard.astro';
import ReportCard from '../components/ReportCard.astro';
import { getCollection } from 'astro:content';

const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const reports = (await getCollection('reports', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

export const prerender = true;
---

<BaseLayout>
  <HeroSection />
  <CryptoTicker />

  <!-- Latest Blog Posts -->
  <section class="section" id="latest-blog">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          <span class="accent">›</span> Latest Posts
        </h2>
        <p class="section-subtitle">Technical deep-dives, system updates, and alpha</p>
      </div>
      <div class="content-grid">
        {blogPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            slug={post.id}
            date={post.data.date}
            description={post.data.description}
            tags={post.data.tags}
          />
        ))}
      </div>
      <div class="section-cta">
        <a href="/blog" class="btn btn--ghost text-mono">View all posts →</a>
      </div>
    </div>
  </section>

  <!-- Latest Reports -->
  <section class="section" id="latest-reports">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">
          <span class="accent">⟫</span> Research Reports
        </h2>
        <p class="section-subtitle">In-depth analysis, updated daily</p>
      </div>
      <div class="content-grid">
        {reports.map((report) => (
          <ReportCard
            title={report.data.title}
            slug={report.id}
            date={report.data.date}
            summary={report.data.summary}
            category={report.data.category}
          />
        ))}
      </div>
      <div class="section-cta">
        <a href="/reports" class="btn btn--ghost text-mono">View all reports →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .content-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }
  .section-cta {
    margin-top: var(--space-8);
    text-align: center;
  }
</style>
