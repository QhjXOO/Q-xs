---
/**
 * reports/index.astro — Research reports listing page
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReportCard from '../../components/ReportCard.astro';
import { getCollection } from 'astro:content';

const reports = (await getCollection('reports', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

export const prerender = true;
---

<BaseLayout title="Research Reports — Q:XS" description="In-depth crypto research, DeFi analysis, and market structure reports.">
  <section class="page-section" id="reports-list">
    <div class="container">
      <div class="page-header">
        <div class="terminal-prefix text-mono">
          <span class="accent">$</span> cat /reports/manifest.json
        </div>
        <h1 class="page-title">Research Reports</h1>
        <p class="page-desc">In-depth analysis and market intelligence, updated daily</p>
      </div>
      <div class="reports-grid">
        {reports.map((report) => (
          <ReportCard
            title={report.data.title}
            slug={report.id}
            date={report.data.date}
            summary={report.data.summary}
            category={report.data.category}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-section {
    padding-top: calc(var(--header-height) + var(--space-12));
    padding-bottom: var(--space-16);
  }
  .page-header {
    margin-bottom: var(--space-12);
  }
  .terminal-prefix {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-bottom: var(--space-3);
  }
  .terminal-prefix .accent { color: var(--accent-green); }
  .page-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-3);
  }
  .page-desc {
    font-size: var(--text-lg);
    color: var(--text-secondary);
  }
  .reports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--space-6);
  }
</style>
